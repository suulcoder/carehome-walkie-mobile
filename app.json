{
  "expo": {
    "name": "Carehome Walkie",
    "slug": "carehome-walkie-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app uses the microphone to send voice messages over the walkie-talkie channel."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e40af",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "react-native-haptic-feedback",
      [
        "@mykin-ai/expo-audio-stream",
        {
          "ios": {
            "microphonePermission": "This app uses the microphone for push-to-talk."
          },
          "android": {
            "audioRecordingPermission": "This app uses the microphone for push-to-talk."
          }
        }
      ]
    ]
  }
}
