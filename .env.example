# Copy to .env.local (gitignored) and adjust for your machine.
# Restart Metro after changes.

# Backend target (default: production — Render)
# EXPO_PUBLIC_WS_ENV=production
# EXPO_PUBLIC_WS_ENV=local
# EXPO_PUBLIC_WS_ENV=network_simulator

# Required on physical devices when using local or network_simulator.
# Android emulator always uses 10.0.2.2; iOS Simulator uses localhost.
# Find your IP: ipconfig getifaddr en0  (macOS)
# EXPO_PUBLIC_DEV_MACHINE_HOST=192.168.1.60

# Wire codec: opus (default) or pcm
# EXPO_PUBLIC_AUDIO_CODEC=pcm

# In-app debug telemetry panel (development builds only)
# EXPO_PUBLIC_SHOW_DEBUG_TELEMETRY=true
