# Copy to .env.local (gitignored) and adjust for your machine.

# Backend target: production | network_simulator | local
# Or change DEFAULT_WS_ENV in src/config/resolveWsUrl.ts
# EXPO_PUBLIC_WS_ENV=network_simulator | production | local

# Used on physical devices (required). Also works on iOS Simulator.
# Android emulator always uses 10.0.2.2 regardless of this value.
# Find your IP: ipconfig getifaddr en0  (macOS)
# EXPO_PUBLIC_DEV_MACHINE_HOST=192.168.1.60
